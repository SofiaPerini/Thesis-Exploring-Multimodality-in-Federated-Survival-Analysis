# Docker run options
docker_args: -v ~/storage_megaverse:/data -v ~/SurvPath--1/temp:/tmp -p 9999:8888
#-v /megaverse/storage/perini/zoorvival:/data -v ~/SurvPath--1/temp:/tmp
 
#-p 9990:8888

# Specify the name of the container
container_name: {user}_survpath{args.gpu}_{date}

# Specify the Docker image to use
image_name: perini/survpath:v2.0